# Frontend (Nuxt). Usa NUXT_PORT para no chocar con el puerto del backend.
NUXT_PORT=9000

# Backend API
API_URL=http://127.0.0.1
API_PORT=8000

# Opcional: URL completa del backend (tiene prioridad sobre API_URL + API_PORT)
# NUXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Endpoint de autenticación (relativo a apiBaseUrl)
# NUXT_PUBLIC_API_AUTH_PATH=/api/auth/login/
# NUXT_PUBLIC_API_AUTH_LOGOUT_PATH=/auth/logout/
